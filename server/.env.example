# Server port
PORT=4000

# CORS — web app origin (Vite dev = 5173)
WEB_ORIGIN=http://localhost:5173

# ITHub upstream
ITHUB_BASE_URL=https://demo.logicalisservice.com
ITHUB_CUSTOMER_TAG=ciscoinnovation1

# Demo credentials (prefilled on login page; can also be overridden by user input)
ITHUB_DEMO_IDENTITY=demo.user
ITHUB_DEMO_PASSWORD=changeme

# Optional: AI Profile / KB IDs for ITHub KB browsing. Not used by the chat
# itself anymore — chat goes direct to MiniMax. Leave blank to skip.
AI_PROFILE_ID=
AI_PROFILE_TAG=
KB_ID=

# Primary AI backend: direct MiniMax (replaces ITHub AI Profile path).
# Set MINIMAX_API_KEY to enable chat. Without it the chat endpoint returns
# "AI 服务暂不可用".
ENABLE_MINIMAX=true
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_MODEL=MiniMax-Text-01

# Session
SESSION_COOKIE_NAME=sid
SESSION_TTL_HOURS=8