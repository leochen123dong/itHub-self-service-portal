# Server port
PORT=4000

# CORS — web app origin (Vite dev = 5173)
WEB_ORIGIN=http://localhost:5173

# ITHub upstream
ITHUB_BASE_URL=https://demo.logicalisservice.com
ITHUB_CUSTOMER_TAG=ciscoinnovation1

# Demo credentials (prefilled on login page; can also be overridden by user input)
ITHUB_DEMO_IDENTITY=demo.user
ITHUB_DEMO_PASSWORD=changeme

# Optional overrides — leave blank to auto-discover at startup
# AI Profile ID for chat (will use first active profile if blank)
AI_PROFILE_ID=
# Tag to filter AI Profile (e.g. "selfservice")
AI_PROFILE_TAG=
# Knowledge Base ID
KB_ID=

# Optional: direct MiniMax LLM fallback when ITHub AI fails
# Leave disabled by default. The portal's primary AI path is ITHub.
ENABLE_MINIMAX_FALLBACK=false
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_MODEL=MiniMax-Text-01

# Session
SESSION_COOKIE_NAME=sid
SESSION_TTL_HOURS=8